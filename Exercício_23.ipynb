        "n = int(input('Digite um número de 0 a 9999: '))\n",
        "u = n // 1 % 10\n",
        "d = n // 10 % 10\n",
        "c = n // 100 % 10\n",
        "m = n // 1000 % 10\n",
        "print(f'O número {n} tem {u} unidades, {d} dezenas, {c} centenas e {m} milhar.')"
