      "source": [
        "from datetime import date\n",
        "n = int(input('Digite o ano que deseja saber se é BISSEXTO. Digite 0 para verificar o ano atual: '))\n",
        "if n == 0:\n",
        "  n = date.today().year\n",
        "if n % 4 == 0 and n % 100 != 0 or n % 400 == 0:\n",
        "  print(f'O ano {n} é BISSEXTO')\n",
        "else:\n",
        "  print(f'O ano {n} não é BISSEXTO')"
      ],
